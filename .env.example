# TEMPLATE — copy this to .env only if you are NOT using the OS keyring.
# Preferred: run  python setup_tokens.py  to store tokens in the OS credential
#   store (macOS Keychain / Windows Credential Manager / Linux Secret Service).
#   The tool reads keyring first; .env is a fallback only.
# NEVER put real tokens in this file or in .env.

# Optional: pre-populate the folder path in the web UI
# ADFS_EXPORT_DIR=/path/to/ADFS_Migration_Export_Folder

